[Unit]
Description=Export encrypted Dreambau test-access recovery data
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
UMask=0077
ExecStart=/usr/local/lib/dreambau/test-access-recovery-export.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/backups/test-access

[Install]
WantedBy=multi-user.target
