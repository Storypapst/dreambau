apiVersion: v1
kind: Secret
metadata:
  name: etherpad-secret
  namespace: wcr
type: Opaque
stringData:
  # Database credentials
  DB_USER: "etherpad"
  DB_PASS: "CHANGE_ME_STRONG_PASSWORD"
  DB_NAME: "etherpad"
  
  # Admin credentials for Etherpad
  ADMIN_PASSWORD: "CHANGE_ME_ADMIN_PASSWORD"
  
  # Session key (generate with: openssl rand -hex 32)
  SESSION_KEY: "CHANGE_ME_SESSION_KEY_64_CHARS"
  
  # API key (generate with: openssl rand -hex 32)
  API_KEY: "CHANGE_ME_API_KEY"


