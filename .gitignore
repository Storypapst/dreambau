# ===========================================
# SECURITY - NEVER COMMIT SENSITIVE DATA
# ===========================================

# Secrets - CRITICAL: Never commit passwords/keys
WCR-Database/mysql/mysql-secret.yaml
WCR-Invoice/config/invoiceninja-secret.yaml
WCR-n8n/config/n8n-secret.yaml
WCR-n8n/config/postgres-secret.yaml
WCR-NocoDB/config/nocodb-secret.yaml
WCR-Cap/config/cap-secret.yaml
Dreambau-Novu/config/novu-secret.yaml
Dreambau-Novu/config/mongodb-deployment.yaml

# Keep example files for reference
!*.yaml.example
!*-example.yaml

# Backups - Never commit database backups
WCR-Database/backups/*.sql
WCR-Database/backups/*.sql.gz
WCR-Backup/
wcr-backups/
*-backups/
*.backup
*.dump

