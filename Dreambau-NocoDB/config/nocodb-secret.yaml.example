apiVersion: v1
kind: Secret
metadata:
  name: nocodb-secret
  namespace: wcr
  labels:
    app: nocodb
    component: application
type: Opaque
stringData:
  # ===========================================
  # DATABASE CONNECTION - REQUIRED
  # ===========================================
  # Uses existing MySQL server in cluster
  # Format: mysql2://host:port?u=username&p=password&d=database
  NC_DB: "mysql2://mysql.wcr.svc.cluster.local:3306?u=nocodb&p=REPLACE_WITH_PASSWORD&d=nocodb"
  
  # Database credentials (for management scripts)
  DB_HOST: "mysql.wcr.svc.cluster.local"
  DB_PORT: "3306"
  DB_DATABASE: "nocodb"
  DB_USER: "nocodb"
  DB_PASSWORD: "REPLACE_WITH_PASSWORD"
  
  # ===========================================
  # APPLICATION CONFIGURATION - REQUIRED
  # ===========================================
  # Public URL (must match ingress)
  NC_PUBLIC_URL: "https://nocodb.yourdomain.com"
  
  # Authentication secret (generate with: openssl rand -base64 32)
  NC_AUTH_JWT_SECRET: "REPLACE_WITH_GENERATED_SECRET"
  
  # ===========================================
  # ADMIN CONFIGURATION - REQUIRED
  # ===========================================
  # Initial admin email (change after first login!)
  NC_ADMIN_EMAIL: "admin@yourdomain.com"
  
  # Initial admin password (change immediately after first login!)
  NC_ADMIN_PASSWORD: "REPLACE_WITH_SECURE_PASSWORD"
  
  # ===========================================
  # OPTIONAL CONFIGURATION
  # ===========================================
  # Disable telemetry (recommended for privacy)
  NC_DISABLE_TELE: "true"
  
  # Enable public signup (false = invite-only)
  NC_INVITE_ONLY_SIGNUP: "true"
  
  # Request size limits
  NC_REQUEST_BODY_SIZE: "104857600"
  
  # Timezone
  TZ: "America/New_York"

