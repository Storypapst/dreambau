apiVersion: v1
kind: Secret
metadata:
  name: mysql-secret
  namespace: wcr
type: Opaque
stringData:
  # ===========================================
  # MYSQL ROOT PASSWORD - REQUIRED
  # ===========================================
  # Generate with: openssl rand -base64 32
  # This is the root administrator password
  MYSQL_ROOT_PASSWORD: "REPLACE_WITH_SECURE_ROOT_PASSWORD"
  
  # ===========================================
  # MYSQL DATABASE CONFIGURATION - REQUIRED
  # ===========================================
  # Database name for InvoiceNinja
  MYSQL_DATABASE: "ninja"
  
  # Database username for InvoiceNinja
  MYSQL_USER: "ninja"
  
  # ===========================================
  # MYSQL USER PASSWORD - REQUIRED
  # ===========================================
  # Generate with: openssl rand -base64 32
  # CRITICAL: This must match DB_PASSWORD in invoiceninja-secret.yaml
  MYSQL_PASSWORD: "REPLACE_WITH_YOUR_MYSQL_PASSWORD"

