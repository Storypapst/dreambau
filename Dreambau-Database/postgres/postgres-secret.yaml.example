apiVersion: v1
kind: Secret
metadata:
  name: shared-postgres-secret
  namespace: wcr
  labels:
    app: shared-postgres
    component: database
type: Opaque
stringData:
  # ===========================================
  # POSTGRESQL ROOT CONFIGURATION
  # ===========================================
  # PostgreSQL superuser password
  # Generate with: openssl rand -base64 32
  POSTGRES_PASSWORD: "CHANGE_ME_Postgres_Root_Pass_2024"
  
  # Default database (postgres is created by default)
  POSTGRES_USER: "postgres"
  POSTGRES_DB: "postgres"
  
  # ===========================================
  # APPLICATION DATABASE CREDENTIALS
  # ===========================================
  # These will be used to create databases and users via init scripts
  
  # NocoDB Database
  NOCODB_DB_NAME: "nocodb"
  NOCODB_DB_USER: "nocodb"
  NOCODB_DB_PASSWORD: "CHANGE_ME_NocoDB_Postgres_Pass_2024"
  
  # Add more application databases here as needed
  # Example:
  # OTHERAPP_DB_NAME: "otherapp"
  # OTHERAPP_DB_USER: "otherapp"
  # OTHERAPP_DB_PASSWORD: "CHANGE_ME_OtherApp_Pass_2024"



