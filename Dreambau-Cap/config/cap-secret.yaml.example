apiVersion: v1
kind: Secret
metadata:
  name: cap-secret
  namespace: wcr
  labels:
    app: cap
    component: application
type: Opaque
stringData:
  # ===========================================
  # DATABASE CONNECTION - REQUIRED
  # ===========================================
  DATABASE_URL: "mysql://cap:YOUR_DB_PASSWORD@mysql.wcr.svc.cluster.local:3306/cap"
  DB_HOST: "mysql.wcr.svc.cluster.local"
  DB_PORT: "3306"
  DB_DATABASE: "cap"
  DB_USER: "cap"
  DB_PASSWORD: "YOUR_DB_PASSWORD"
  
  # ===========================================
  # APPLICATION CONFIGURATION - REQUIRED
  # ===========================================
  NEXT_PUBLIC_URL: "https://cap.wcrbusiness.online"
  NEXTAUTH_URL: "https://cap.wcrbusiness.online"
  NEXTAUTH_SECRET: "GENERATE_WITH_openssl_rand_base64_32"
  
  # ===========================================
  # STORAGE CONFIGURATION
  # ===========================================
  STORAGE_TYPE: "local"
  STORAGE_PATH: "/app/storage"
  
  # ===========================================
  # APPLICATION SETTINGS
  # ===========================================
  NODE_ENV: "production"
  PORT: "3000"
  TZ: "America/New_York"

