apiVersion: v1
kind: Secret
metadata:
  name: invoiceninja-secret
  namespace: wcr
type: Opaque
stringData:
  # ===========================================
  # APPLICATION KEY - REQUIRED
  # ===========================================
  # Generate with: echo "base64:$(openssl rand -base64 32)"
  # Example: base64:6+cLglUenjzujq5sVx4WaTPpd5MPr5tiyVdeFKxtLE4=
  APP_KEY: "base64:REPLACE_WITH_YOUR_GENERATED_KEY"
  
  # ===========================================
  # DATABASE CONFIGURATION - REQUIRED
  # ===========================================
  # Database host (internal Kubernetes service)
  DB_HOST: "mysql.wcr.svc.cluster.local"
  DB_PORT: "3306"
  DB_DATABASE: "ninja"
  DB_USERNAME: "ninja"
  
  # IMPORTANT: Must match MYSQL_PASSWORD in mysql-secret.yaml
  # Generate with: openssl rand -base64 32
  DB_PASSWORD: "REPLACE_WITH_YOUR_MYSQL_PASSWORD"
  
  # ===========================================
  # APPLICATION CONFIGURATION - REQUIRED
  # ===========================================
  # Your domain name (must match ingress configuration)
  APP_URL: "https://invoice.yourdomain.com"
  
  # Environment (production recommended for live servers)
  APP_ENV: "production"
  
  # Debug mode (false for production)
  APP_DEBUG: "false"
  
  # ===========================================
  # MAIL CONFIGURATION - OPTIONAL
  # ===========================================
  # Can be configured later via web interface
  # For Gmail: Use App Password (not regular password)
  MAIL_MAILER: "smtp"
  MAIL_HOST: "smtp.gmail.com"
  MAIL_PORT: "587"
  MAIL_USERNAME: "your-email@gmail.com"
  MAIL_PASSWORD: "your-app-password"
  MAIL_ENCRYPTION: "tls"
  MAIL_FROM_ADDRESS: "noreply@invoice.yourdomain.com"
  MAIL_FROM_NAME: "Your Company Name"
  
  # ===========================================
  # ADDITIONAL SETTINGS
  # ===========================================
  # Force HTTPS (recommended for production)
  REQUIRE_HTTPS: "true"
  
  # Trust all proxies (required for Traefik ingress)
  TRUSTED_PROXIES: "*"
  
  # PDF Generation (snappdf is recommended)
  PHANTOMJS_PDF_GENERATION: "false"
  PDF_GENERATOR: "snappdf"
  
  # View compilation path
  VIEW_COMPILED_PATH: "/var/www/app/storage/framework/views"

