apiVersion: v1
kind: Secret
metadata:
  name: n8n-secret
  namespace: wcr
type: Opaque
stringData:
  # ===========================================
  # N8N CONFIGURATION - REQUIRED
  # ===========================================
  # Your n8n domain (must match ingress)
  N8N_HOST: "n8n.yourdomain.com"
  
  # Webhook URL (same as host)
  WEBHOOK_URL: "https://n8n.yourdomain.com"
  
  # Protocol (https for production)
  N8N_PROTOCOL: "https"
  
  # Port (internal container port)
  N8N_PORT: "5678"
  
  # ===========================================
  # DATABASE CONFIGURATION - REQUIRED
  # ===========================================
  DB_TYPE: "postgresdb"
  DB_POSTGRESDB_HOST: "n8n-postgres.wcr.svc.cluster.local"
  DB_POSTGRESDB_PORT: "5432"
  DB_POSTGRESDB_DATABASE: "n8n"
  DB_POSTGRESDB_USER: "n8n"
  # Generate with: openssl rand -base64 32
  DB_POSTGRESDB_PASSWORD: "REPLACE_WITH_GENERATED_PASSWORD"
  
  # ===========================================
  # ENCRYPTION KEY - REQUIRED
  # ===========================================
  # Generate with: openssl rand -base64 32
  # CRITICAL: Never change this after first deployment!
  N8N_ENCRYPTION_KEY: "REPLACE_WITH_GENERATED_KEY_DO_NOT_CHANGE"
  
  # ===========================================
  # TIMEZONE & LOCALE
  # ===========================================
  GENERIC_TIMEZONE: "America/New_York"
  TZ: "America/New_York"
  
  # ===========================================
  # EXECUTIONS & PERFORMANCE
  # ===========================================
  EXECUTIONS_DATA_SAVE_ON_SUCCESS: "all"
  EXECUTIONS_DATA_SAVE_ON_ERROR: "all"
  EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS: "true"
  EXECUTIONS_TIMEOUT: "3600"
  EXECUTIONS_TIMEOUT_MAX: "7200"

